APP_ENV=production
APP_NAME=anotaai

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

DATABASE_URL=postgresql+psycopg://anotaai:anotaai@postgres:5432/anotaai
REDIS_URL=redis://redis:6379/0

S3_ENDPOINT=http://minio:9000
S3_BUCKET=anotaai-private
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_CONNECT_TIMEOUT_SECONDS=5
S3_READ_TIMEOUT_SECONDS=120
S3_DOWNLOAD_CHUNK_SIZE=1048576

JWT_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
AI_SETTINGS_ENCRYPTION_KEY=change-me-user-ai-secrets

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.inovv.co/ai/v1/dev
LLM_API_KEY=
LLM_MODEL=gemma3:4b
LLM_TIMEOUT_SECONDS=120

TRANSCRIPTION_PROVIDER=local_whisper
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
EMBEDDINGS_PROVIDER=local

JOB_QUEUE_KEY=anotaai:jobs
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_CONSOLE_PORT=9001
